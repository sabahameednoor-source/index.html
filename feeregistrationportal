<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>School Fee Registration Portal</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
    <style>
        body, html {
            margin: 0;
            padding: 0;
            overflow-x: hidden;
            overflow-y: auto;
            font-family: 'Inter', sans-serif;
            height: 100%;
            background: #0f172a;
        }

        #bg-canvas {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: -1;
        }

        .view-container {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 40px 20px;
            transition: all 0.5s ease;
            position: relative;
            z-index: 10;
        }

        .glass-card {
            background: rgba(255, 255, 255, 0.9);
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
            border: 1px solid rgba(255, 255, 255, 0.4);
            border-radius: 1.5rem;
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.6);
        }

        .hidden {
            display: none !important;
        }

        .fade-in {
            animation: fadeIn 0.6s ease forwards;
        }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .dashboard-grid {
            display: grid;
            grid-template-columns: 260px 1fr;
            width: 95%;
            max-width: 1200px;
            min-height: 85vh;
        }

        .payment-option-active {
            border-color: #6366f1 !important;
            background-color: #eef2ff !important;
            color: #4338ca !important;
        }

        @media (max-width: 1024px) {
            .dashboard-grid {
                grid-template-columns: 1fr;
                height: auto;
            }
            .sidebar { display: none; }
        }

        input:focus, select:focus {
            background-color: white !important;
        }
    </style>
</head>
<body>

    <canvas id="bg-canvas"></canvas>

    <!-- STEP 1: REGISTRATION VIEW -->
    <div id="registration-view" class="view-container">
        <div class="glass-card w-full max-w-md p-8 md:p-10 fade-in">
            <div class="text-center mb-8">
                <div class="inline-flex items-center justify-center w-20 h-20 bg-indigo-600 text-white rounded-2xl mb-4 shadow-xl transform -rotate-3">
                    <i class="fas fa-graduation-cap text-3xl"></i>
                </div>
                <h1 class="text-3xl font-black text-indigo-950 tracking-tight">Portal Access</h1>
                <p class="text-indigo-700/70 font-medium mt-2">Register to manage your school fees</p>
            </div>

            <form id="registrationForm" class="space-y-5">
                <div class="space-y-1">
                    <label for="name" class="block text-xs font-bold text-indigo-900 uppercase tracking-widest ml-1">Full Name</label>
                    <div class="relative">
                        <span class="absolute inset-y-0 left-0 pl-4 flex items-center text-indigo-400">
                            <i class="fas fa-user"></i>
                        </span>
                        <input type="text" id="name" name="name" required
                            class="block w-full pl-11 pr-4 py-3.5 border border-indigo-100 rounded-2xl bg-white/60 focus:outline-none focus:ring-2 focus:ring-indigo-500 transition duration-200 text-sm shadow-sm"
                            placeholder="e.g. John Smith">
                    </div>
                </div>

                <div class="space-y-1">
                    <label for="email" class="block text-xs font-bold text-indigo-900 uppercase tracking-widest ml-1">Email Address</label>
                    <div class="relative">
                        <span class="absolute inset-y-0 left-0 pl-4 flex items-center text-indigo-400">
                            <i class="fas fa-envelope"></i>
                        </span>
                        <input type="email" id="email" name="email" required
                            class="block w-full pl-11 pr-4 py-3.5 border border-indigo-100 rounded-2xl bg-white/60 focus:outline-none focus:ring-2 focus:ring-indigo-500 transition duration-200 text-sm shadow-sm"
                            placeholder="john@example.com">
                    </div>
                </div>

                <div class="grid grid-cols-2 gap-4">
                    <div class="space-y-1">
                        <label for="age" class="block text-xs font-bold text-indigo-900 uppercase tracking-widest ml-1">Age</label>
                        <input type="number" id="age" name="age" required min="4" max="100"
                            class="block w-full px-4 py-3.5 border border-indigo-100 rounded-2xl bg-white/60 focus:outline-none focus:ring-2 focus:ring-indigo-500 transition duration-200 text-sm shadow-sm"
                            placeholder="15">
                    </div>
                    <div class="space-y-1">
                        <label for="gender" class="block text-xs font-bold text-indigo-900 uppercase tracking-widest ml-1">Gender</label>
                        <select id="gender" name="gender" required
                            class="block w-full px-4 py-3.5 border border-indigo-100 rounded-2xl bg-white/60 focus:outline-none focus:ring-2 focus:ring-indigo-500 transition duration-200 text-sm shadow-sm appearance-none cursor-pointer">
                            <option value="" disabled selected>Select</option>
                            <option value="male">Male</option>
                            <option value="female">Female</option>
                        </select>
                    </div>
                </div>

                <div class="space-y-1">
                    <label for="whatsapp" class="block text-xs font-bold text-indigo-900 uppercase tracking-widest ml-1">WhatsApp Number</label>
                    <div class="relative">
                        <span class="absolute inset-y-0 left-0 pl-4 flex items-center text-indigo-400">
                            <i class="fab fa-whatsapp"></i>
                        </span>
                        <input type="tel" id="whatsapp" name="whatsapp" required
                            class="block w-full pl-11 pr-4 py-3.5 border border-indigo-100 rounded-2xl bg-white/60 focus:outline-none focus:ring-2 focus:ring-indigo-500 transition duration-200 text-sm shadow-sm"
                            placeholder="+1 234 567 8900">
                    </div>
                </div>

                <div class="pt-2">
                    <button type="submit"
                        class="w-full flex justify-center py-4 px-4 border border-transparent rounded-2xl shadow-xl text-sm font-black text-white bg-indigo-600 hover:bg-indigo-700 transform hover:scale-[1.02] active:scale-[0.98] transition-all duration-200 uppercase tracking-widest">
                        Enter Dashboard
                    </button>
                </div>
            </form>
        </div>
    </div>

    <!-- STEP 2: DASHBOARD VIEW -->
    <div id="dashboard-view" class="view-container hidden">
        <div class="glass-card dashboard-grid overflow-hidden fade-in">
            <!-- Sidebar -->
            <aside class="sidebar bg-indigo-900/5 p-6 border-r border-white/20">
                <div class="flex items-center space-x-3 mb-10">
                    <div class="w-10 h-10 bg-indigo-600 rounded-xl flex items-center justify-center text-white shadow-lg">
                        <i class="fas fa-school"></i>
                    </div>
                    <span class="font-black text-indigo-950 text-xl tracking-tight">EDU-Portal</span>
                </div>
                
                <nav class="space-y-3">
                    <a href="#" class="flex items-center space-x-3 p-3.5 bg-white shadow-sm rounded-xl text-indigo-600 font-bold border border-indigo-50">
                        <i class="fas fa-th-large"></i> <span>Dashboard</span>
                    </a>
                    <a href="#" class="flex items-center space-x-3 p-3.5 text-gray-500 hover:bg-white/50 rounded-xl transition font-semibold">
                        <i class="fas fa-receipt"></i> <span>Fee Status</span>
                    </a>
                    <a href="#" class="flex items-center space-x-3 p-3.5 text-gray-500 hover:bg-white/50 rounded-xl transition font-semibold">
                        <i class="fas fa-user-graduate"></i> <span>Student Profile</span>
                    </a>
                </nav>

                <div class="mt-auto pt-20">
                    <button onclick="location.reload()" class="flex items-center space-x-3 p-4 text-red-500 hover:bg-red-50 w-full rounded-2xl transition font-black uppercase tracking-wider text-xs shadow-sm bg-white/50">
                        <i class="fas fa-sign-out-alt"></i> <span>Logout</span>
                    </button>
                </div>
            </aside>

            <!-- Main Content -->
            <main class="p-6 md:p-10 overflow-y-auto bg-white/20">
                <header class="flex flex-col md:flex-row justify-between items-start md:items-center mb-10 gap-4">
                    <div>
                        <h2 class="text-3xl font-black text-indigo-950">Hello, <span id="display-name" class="text-indigo-600">Student</span></h2>
                        <p class="text-indigo-800/50 font-medium">Manage your school finances and sessions</p>
                    </div>
                    <div class="flex items-center space-x-4 bg-white/50 p-2 rounded-2xl border border-white/40 shadow-sm">
                        <div class="w-10 h-10 bg-white rounded-xl flex items-center justify-center text-indigo-600 shadow-sm">
                            <i class="fas fa-bell"></i>
                        </div>
                        <div class="flex items-center space-x-3 pr-2">
                            <img src="" alt="Avatar" id="user-avatar" class="w-10 h-10 rounded-xl border-2 border-white shadow-md">
                        </div>
                    </div>
                </header>

                <!-- Stats Cards -->
                <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-10">
                    <div class="bg-indigo-600 p-8 rounded-3xl text-white shadow-2xl relative overflow-hidden group">
                        <div class="absolute -right-4 -top-4 text-white/10 text-8xl transform group-hover:scale-110 transition duration-500">
                            <i class="fas fa-wallet"></i>
                        </div>
                        <p class="text-indigo-100 text-xs font-black uppercase tracking-widest">Total Due</p>
                        <h3 class="text-4xl font-black mt-2 tracking-tight">$4,500.00</h3>
                        <div class="mt-6 flex items-center text-xs font-bold bg-white/20 w-max px-3 py-1.5 rounded-full">
                            <i class="fas fa-clock mr-1.5"></i> Next: Nov 01
                        </div>
                    </div>

                    <div class="bg-white p-8 rounded-3xl shadow-xl border border-indigo-50 group">
                        <p class="text-gray-400 text-xs font-black uppercase tracking-widest">Paid Amount</p>
                        <h3 class="text-4xl font-black text-gray-900 mt-2 tracking-tight">$3,200</h3>
                        <div class="w-full bg-gray-100 h-2.5 rounded-full mt-6 overflow-hidden">
                            <div class="bg-green-500 h-full rounded-full transition-all duration-1000 ease-out" style="width: 71%"></div>
                        </div>
                        <p class="text-[10px] font-bold text-green-600 mt-2">71% COMPLETED</p>
                    </div>

                    <div class="bg-white p-8 rounded-3xl shadow-xl border border-indigo-50">
                        <p class="text-gray-400 text-xs font-black uppercase tracking-widest">Outstanding</p>
                        <h3 class="text-4xl font-black text-red-500 mt-2 tracking-tight">$1,300</h3>
                        <button class="mt-6 text-xs font-black text-indigo-600 hover:text-indigo-800 transition uppercase tracking-widest flex items-center">
                            View History <i class="fas fa-arrow-right ml-2"></i>
                        </button>
                    </div>
                </div>

                <!-- Fee Registration Form -->
                <div class="bg-white p-8 md:p-10 rounded-3xl shadow-2xl border border-white/60 relative overflow-hidden">
                    <div class="flex items-center justify-between mb-8">
                        <h3 class="text-xl font-black text-indigo-950 flex items-center">
                            <span class="w-8 h-8 bg-indigo-100 text-indigo-600 rounded-lg flex items-center justify-center mr-3">
                                <i class="fas fa-plus text-sm"></i>
                            </span>
                            Fee Registration
                        </h3>
                        <span class="text-[10px] font-black bg-indigo-50 text-indigo-600 px-3 py-1 rounded-full uppercase tracking-widest border border-indigo-100">Safe Payment</span>
                    </div>
                    
                    <form id="feeForm" class="space-y-8">
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                            <div class="space-y-2">
                                <label class="text-xs font-black text-gray-500 uppercase tracking-widest">Select Category</label>
                                <select class="w-full p-4 bg-gray-50 border border-gray-100 rounded-2xl focus:ring-2 focus:ring-indigo-500 outline-none text-sm font-semibold text-gray-700 cursor-pointer">
                                    <option>Tuition Fee (Current Quarter)</option>
                                    <option>Annual Exam Registration</option>
                                    <option>Monthly Transportation</option>
                                    <option>Laboratory & Tech Fee</option>
                                </select>
                            </div>
                            <div class="space-y-2">
                                <label class="text-xs font-black text-gray-500 uppercase tracking-widest">Payment Amount ($)</label>
                                <input type="number" placeholder="0.00" class="w-full p-4 bg-gray-50 border border-gray-100 rounded-2xl focus:ring-2 focus:ring-indigo-500 outline-none text-sm font-semibold">
                            </div>
                        </div>

                        <div class="space-y-4">
                            <label class="text-xs font-black text-gray-500 uppercase tracking-widest block">Choose Payment Method</label>
                            <div class="flex space-x-4">
                                <!-- JazzCash / EasyPaisa Option (Trigger for Mobile Wallets) -->
                                <button type="button" id="btn-wallets" onclick="togglePaymentMethod('wallets')" 
                                    class="flex-1 flex flex-col items-center justify-center p-6 border-2 border-indigo-50 rounded-2xl cursor-pointer hover:bg-indigo-50 transition group bg-gray-50/50">
                                    <div class="text-2xl mb-2 text-indigo-400 group-hover:text-indigo-600">
                                        <i class="fas fa-mobile-alt"></i>
                                    </div>
                                    <span class="text-[11px] font-black uppercase tracking-wider text-gray-500 group-hover:text-indigo-700">JazzCash / EasyPaisa</span>
                                </button>
                                
                                <!-- Bank Transfer Option -->
                                <button type="button" id="btn-bank" onclick="togglePaymentMethod('bank')"
                                    class="flex-1 flex flex-col items-center justify-center p-6 border-2 border-indigo-50 rounded-2xl cursor-pointer hover:bg-indigo-50 transition group bg-gray-50/50">
                                    <div class="text-2xl mb-2 text-indigo-400 group-hover:text-indigo-600">
                                        <i class="fas fa-university"></i>
                                    </div>
                                    <span class="text-[11px] font-black uppercase tracking-wider text-gray-500 group-hover:text-indigo-700">Bank Transfer</span>
                                </button>
                            </div>
                        </div>

                        <!-- SECTION: JAZZCASH / EASYPAISA DETAILS -->
                        <div id="payment-wallets" class="hidden space-y-4 p-6 bg-indigo-50/50 rounded-2xl border border-indigo-100 fade-in">
                            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                                <div class="space-y-2">
                                    <label class="text-[10px] font-black text-indigo-400 uppercase">Select Wallet</label>
                                    <div class="flex space-x-2">
                                        <label class="flex-1 p-3 bg-white border border-indigo-100 rounded-xl flex items-center justify-center cursor-pointer hover:bg-indigo-50">
                                            <input type="radio" name="wallet-type" class="mr-2"> <span class="text-xs font-bold">JazzCash</span>
                                        </label>
                                        <label class="flex-1 p-3 bg-white border border-indigo-100 rounded-xl flex items-center justify-center cursor-pointer hover:bg-indigo-50">
                                            <input type="radio" name="wallet-type" class="mr-2"> <span class="text-xs font-bold">EasyPaisa</span>
                                        </label>
                                    </div>
                                </div>
                                <div class="space-y-2">
                                    <label class="text-[10px] font-black text-indigo-400 uppercase">Mobile Number</label>
                                    <input type="tel" placeholder="03XX-XXXXXXX" class="w-full p-3 bg-white border border-indigo-100 rounded-xl focus:ring-2 focus:ring-indigo-500 outline-none text-sm font-semibold">
                                </div>
                            </div>
                            <p class="text-[10px] text-indigo-700/60 font-bold italic">* A push notification will be sent to your mobile device.</p>
                        </div>

                        <!-- SECTION: BANK DETAILS -->
                        <div id="payment-bank" class="hidden space-y-4 p-6 bg-gray-50 rounded-2xl border border-gray-200 fade-in">
                            <div class="bg-white p-4 rounded-xl border border-gray-100 space-y-3">
                                <div class="flex justify-between items-center border-b border-gray-50 pb-2">
                                    <span class="text-[10px] font-black text-gray-400 uppercase">Bank Name</span>
                                    <span class="text-sm font-bold text-gray-800 tracking-tight">Standard Chartered Bank</span>
                                </div>
                                <div class="flex justify-between items-center border-b border-gray-50 pb-2">
                                    <span class="text-[10px] font-black text-gray-400 uppercase">Account Title</span>
                                    <span class="text-sm font-bold text-gray-800 tracking-tight">Main City High School</span>
                                </div>
                                <div class="flex justify-between items-center">
                                    <span class="text-[10px] font-black text-gray-400 uppercase">IBAN / Account #</span>
                                    <span class="text-sm font-bold text-indigo-600 font-mono tracking-tighter">PK00 SCBL 0123 4567 8910</span>
                                </div>
                            </div>
                            <div class="space-y-2">
                                <label class="text-[10px] font-black text-gray-500 uppercase">Upload Transaction Receipt</label>
                                <input type="file" class="w-full p-2 bg-white border border-gray-200 rounded-xl text-xs font-bold text-gray-500">
                            </div>
                        </div>

                        <div class="pt-4">
                            <button type="button" onclick="handleFeeSubmit()" class="w-full py-4 bg-indigo-600 text-white font-black rounded-2xl shadow-xl hover:bg-indigo-700 transform hover:scale-[1.01] active:scale-[0.99] transition-all uppercase tracking-widest text-xs">
                                Confirm & Submit Payment
                            </button>
                        </div>
                    </form>
                </div>
            </main>
        </div>
    </div>

    <script>
        // --- THREE.JS BACKGROUND ---
        let scene, camera, renderer, shapes = [];
        let mouseX = 0, mouseY = 0, targetX = 0, targetY = 0;
        const windowHalfX = window.innerWidth / 2, windowHalfY = window.innerHeight / 2;

        function init3D() {
            scene = new THREE.Scene();
            camera = new THREE.PerspectiveCamera(75, window.innerWidth / window.innerHeight, 0.1, 1000);
            camera.position.z = 6;
            renderer = new THREE.WebGLRenderer({ canvas: document.getElementById('bg-canvas'), antialias: true, alpha: true });
            renderer.setSize(window.innerWidth, window.innerHeight);
            renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));

            scene.add(new THREE.AmbientLight(0xffffff, 0.6));
            const p1 = new THREE.PointLight(0x6366f1, 2); p1.position.set(5, 5, 5); scene.add(p1);
            const p2 = new THREE.PointLight(0xa855f7, 2); p2.position.set(-5, -5, 2); scene.add(p2);

            const geometries = [new THREE.IcosahedronGeometry(1.2, 0), new THREE.TorusGeometry(0.8, 0.2, 16, 100)];
            for (let i = 0; i < 20; i++) {
                const mesh = new THREE.Mesh(geometries[i % 2], new THREE.MeshPhongMaterial({ color: i % 2 === 0 ? 0x6366f1 : 0xec4899, wireframe: true, transparent: true, opacity: 0.25 }));
                mesh.position.set((Math.random() - 0.5) * 20, (Math.random() - 0.5) * 20, (Math.random() - 0.5) * 10);
                mesh.userData = { rotationSpeed: (Math.random() - 0.5) * 0.008 };
                shapes.push(mesh); scene.add(mesh);
            }
            document.addEventListener('mousemove', (e) => { mouseX = (e.clientX - windowHalfX) * 0.0004; mouseY = (e.clientY - windowHalfY) * 0.0004; });
            window.addEventListener('resize', () => {
                camera.aspect = window.innerWidth / window.innerHeight; camera.updateProjectionMatrix();
                renderer.setSize(window.innerWidth, window.innerHeight);
            });
        }

        function animate() {
            requestAnimationFrame(animate);
            targetX += (mouseX - targetX) * 0.05; targetY += (mouseY - targetY) * 0.05;
            camera.position.x = targetX * 12; camera.position.y = -targetY * 12;
            camera.lookAt(scene.position);
            shapes.forEach(s => { s.rotation.x += s.userData.rotationSpeed; s.rotation.y += s.userData.rotationSpeed; });
            renderer.render(scene, camera);
        }

        // --- PAYMENT TOGGLE LOGIC ---
        let selectedMethod = null;

        function togglePaymentMethod(method) {
            selectedMethod = method;
            const walletPanel = document.getElementById('payment-wallets');
            const bankPanel = document.getElementById('payment-bank');
            const walletBtn = document.getElementById('btn-wallets');
            const bankBtn = document.getElementById('btn-bank');

            // Reset UI
            walletPanel.classList.add('hidden');
            bankPanel.classList.add('hidden');
            walletBtn.classList.remove('payment-option-active');
            bankBtn.classList.remove('payment-option-active');

            // Apply Selection
            if (method === 'wallets') {
                walletPanel.classList.remove('hidden');
                walletBtn.classList.add('payment-option-active');
            } else {
                bankPanel.classList.remove('hidden');
                bankBtn.classList.add('payment-option-active');
            }
        }

        function handleFeeSubmit() {
            if (!selectedMethod) {
                alert("Please select a payment method first.");
                return;
            }
            const msg = selectedMethod === 'wallets' 
                ? "Payment link sent to your mobile app! Please approve the transaction."
                : "Thank you for the transfer. Your receipt has been uploaded for verification.";
            alert(msg);
        }

        // --- TRANSITION LOGIC ---
        const regForm = document.getElementById('registrationForm');
        const regView = document.getElementById('registration-view');
        const dashView = document.getElementById('dashboard-view');
        const displayName = document.getElementById('display-name');
        const userAvatar = document.getElementById('user-avatar');

        regForm.addEventListener('submit', (e) => {
            e.preventDefault();
            const name = document.getElementById('name').value;
            regView.style.opacity = '0';
            setTimeout(() => {
                regView.classList.add('hidden');
                dashView.classList.remove('hidden');
                displayName.innerText = name;
                userAvatar.src = `https://ui-avatars.com/api/?name=${encodeURIComponent(name)}&background=6366f1&color=fff&size=128&bold=true`;
                window.scrollTo(0, 0);
            }, 500);
        });

        window.onload = function() { init3D(); animate(); };
    </script>
</body>
</html>
